(ns re-dash.core
  (:require [ren-finance.model.subs :as subs]
            [ren-finance.model.events :as events]))

(defn dispatch [event & args]
  (let [ev (if (vector? event) event (apply vector event args))]
    (events/dispatch ev)))

(defn subscribe [key]
  (let [k (if (vector? key) (first key) key)]
    (get @subs/app-state k)))
